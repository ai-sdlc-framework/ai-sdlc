# AISDLC-371: attestation-only commit short-circuit.
# When every staged file is an attestation envelope (.ai-sdlc/attestations/<sha>.dsse.json),
# skip the expensive tsc + lint-staged checks — they cannot flag anything in a JSON envelope.
# Saves ~10-15s per chore-sign commit on PRs that go through multiple re-sign cycles.
STAGED=$(git diff --cached --name-only)
if [ -n "$STAGED" ] && ! echo "$STAGED" | grep -qvE '^\.ai-sdlc/attestations/[a-f0-9]+\.dsse\.json$'; then
  echo "[pre-commit] attestation-only commit — skipping tsc and lint-staged"
  exit 0
fi

pnpm exec lint-staged
pnpm typecheck

# >>> backlog-drift strict pre-commit gate (AISDLC-119) >>>
# Replaces the legacy advisory `npx backlog-drift hook-run` (exited 0 on errors).
# Strict mode runs `backlog-drift check --task <id>` per staged backlog/tasks/*.md
# and FAILS the commit on drift errors.
# Escape: AI_SDLC_SKIP_DRIFT_GATE=1 git commit ...  OR  git commit --no-verify
./scripts/check-backlog-drift.sh
# <<< backlog-drift strict pre-commit gate (AISDLC-119) <<<
