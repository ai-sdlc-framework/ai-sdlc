#!/usr/bin/env bash
# Husky pre-push hook. Order matters:
#
#   1. Coverage gate (existing) — fails fast on under-tested code so we don't
#      sign an attestation for a build we'd reject anyway.
#      NOTE: pnpm test:coverage is known to show transient failures (up to 17
#      tests across 3 files) when multiple worktrees run pre-push hooks
#      concurrently and share /tmp space. If you see intermittent failures,
#      retry with AI_SDLC_SKIP_COVERAGE_GATE=1 git push once, then re-run
#      coverage in isolation. See docs/operations/merge-queue-rebase-recovery.md
#      "Coverage gate flake" section for the full retry recipe (AISDLC-357).
#   2. Auto-close backlog task (AISDLC-220) — when any commit in the push range
#      has `(AISDLC-N)` in its subject and the task file is still in
#      `backlog/tasks/`, moves the file to `backlog/completed/` via the
#      AISDLC-203 atomic helper and commits the move as a chore commit, then
#      exits 1 with "re-push required". ORDER IS LOAD-BEARING — MUST run
#      BEFORE attestation-sign (item 4 below). The attestation envelope's
#      `contentHashV4` field binds `{path, headBlobSha}` per changed file;
#      if the task move happens AFTER attestation sign, the envelope hashes the
#      OLD path (`backlog/tasks/…`) while the PR diff contains the NEW path
#      (`backlog/completed/…`) — verify-attestation would reject the envelope.
#   3. MCP server bundle sync (AISDLC-357) — when any commit in the push range
#      touches `pipeline-cli/src/**`, rebuilds `@ai-sdlc/plugin-mcp-server`
#      and commits the updated `dist/bin.js` if it changed, then exits 1 with
#      "re-push required". ORDER IS LOAD-BEARING — MUST run BEFORE
#      attestation-sign (item 4 below): the attestation envelope binds
#      {path, headBlobSha} per changed file; if the bundle rebuild happens
#      AFTER attestation sign, the envelope hashes the OLD bundle while the
#      PR diff contains the NEW bundle → verify-attestation rejects.
#   4. Squash stacked chore-sign commits (AISDLC-369) — when multiple
#      consecutive "chore: sign attestation" commits accumulate at HEAD
#      (from re-sign cycles), squashes them into one to keep history clean.
#      ORDER: MUST run BEFORE attestation-sign (item 5 below) so the
#      squashed HEAD is the one the attestation is signed against.
#      No-op when there is 0 or 1 chore-sign commit at HEAD.
#   5. Auto-sign attestation (AISDLC-133) — when the worktree has an active
#      task + reviewer verdict file but no attestation at current HEAD, signs
#      a chore commit on top + exits 1 with "re-push required". This removes
#      the sign-attestation step from /ai-sdlc execute's LLM responsibility
#      (per the 2026-05-01 "mechanical → hook, never LLM" design discussion).
#
# Skip individual gates with their respective env vars
# (AI_SDLC_SKIP_COVERAGE_GATE=1, AI_SDLC_SKIP_TASK_MOVE=1,
# AI_SDLC_SKIP_MCP_BUNDLE_SYNC=1, AI_SDLC_SKIP_SQUASH_CHORES=1,
# AI_SDLC_SKIP_ATTESTATION_SIGN=1)
# or skip all pre-push hooks via `git push --no-verify` (use sparingly —
# these gates exist because the things they guard have failed silently in
# the past).

set -euo pipefail

./scripts/check-coverage.sh
./scripts/check-task-moved.sh
./scripts/check-mcp-bundle-sync.sh
if [ "${AI_SDLC_SKIP_SQUASH_CHORES:-}" != "1" ]; then
  ./scripts/squash-attestation-chores.sh
fi
./scripts/check-attestation-sign.sh
