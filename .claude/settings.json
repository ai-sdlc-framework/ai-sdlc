{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/ai-sdlc-plugin/hooks/session-start.sh\"",
            "statusMessage": "Loading AI-SDLC governance..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/ai-sdlc-plugin/hooks/enforce-blocked-actions.sh\"",
            "if": "Bash(*)",
            "statusMessage": "Checking action policy..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/ai-sdlc-plugin/hooks/collect-tool-sequence.sh\"",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/ai-sdlc-plugin/hooks/permission-check.sh\"",
            "if": "Bash(gh pr merge*)"
          }
        ]
      }
    ]
  }
}
